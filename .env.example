# ─── Primary Auth (ChatGPT Plus / Pro subscription) ──────────────────────────
# By default the proxy reads ~/.codex/auth.json written by `codex login`.
# Override the path here if needed:
# CODEX_AUTH_PATH=/path/to/auth.json

# ─── Fallback Auth (bare OpenAI API key) ─────────────────────────────────────
# If auth.json is not present, the proxy falls back to this key and routes
# requests through https://api.openai.com/v1/responses instead.
# OPENAI_API_KEY=sk-proj-...

# ─── Backend URL override ─────────────────────────────────────────────────────
# Default: auto-selected based on auth type
#   ChatGPT auth  → https://chatgpt.com/backend-api/codex/responses
#   API key auth  → https://api.openai.com/v1/responses
# CODEX_BACKEND_URL=https://chatgpt.com/backend-api/codex/responses

# ─── Default model override ───────────────────────────────────────────────────
# When set, generic model aliases (gpt-4o, gpt-3.5-turbo, etc.) are mapped to
# this model instead of the built-in mapping. Explicit Codex model IDs are
# always passed through unchanged.
# CODEX_DEFAULT_MODEL=codex-mini

# ─── MCP server ───────────────────────────────────────────────────────────────
# Run the MCP Streamable HTTP server alongside the HTTP proxy on this port.
# MCP_HTTP_PORT=8081

# ─── Server settings ──────────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8080

# ─── Logging ──────────────────────────────────────────────────────────────────
# RUST_LOG=openai_proxy=debug
